FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir "fastapi>=0.104.0" "uvicorn[standard]>=0.24.0" "python-multipart>=0.0.9"

COPY . .

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "interfaces.webapp.app:app", "--host", "0.0.0.0", "--port", "8080"]
